<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AINotebook.App.Views.NotebookDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="24,24,24,16" Spacing="4">
            <TextBlock Text="{x:Bind ViewModel.Notebook.Name, Mode=OneWay}"
                       Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind ViewModel.Notebook.Description, Mode=OneWay}"
                       Opacity="0.8"
                       Visibility="{x:Bind ViewModel.Notebook.Description, Mode=OneWay, Converter={StaticResource NullToCollapsed}}" />
            <TextBlock Text="{x:Bind ViewModel.Notebook.CreatedAt, Mode=OneWay}"
                       Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>

        <!-- 5-tab switcher fills remaining space -->
        <Pivot Grid.Row="1" x:Name="Tabs"
               SelectedIndex="{x:Bind TabIndex, Mode=TwoWay}"
               Margin="16,0,16,16">
            <PivotItem Header="{x:Bind ViewModel.SourcesText, Mode=OneWay}">
                <Grid x:Name="SourcesHost" />
            </PivotItem>
            <PivotItem Header="{x:Bind ViewModel.ChatText, Mode=OneWay}">
                <Grid x:Name="ChatHost" />
            </PivotItem>
            <PivotItem Header="{x:Bind ViewModel.NotesText, Mode=OneWay}">
                <Grid x:Name="NotesHost" />
            </PivotItem>
            <PivotItem Header="{x:Bind ViewModel.TransformationsText, Mode=OneWay}">
                <Grid x:Name="TransformationsHost" />
            </PivotItem>
            <!-- C1: per-notebook AI instructions -->
            <PivotItem Header="{x:Bind ViewModel.SettingsText, Mode=OneWay}">
                <ScrollViewer Padding="4,8">
                    <StackPanel Spacing="12" MaxWidth="640">
                        <TextBlock x:Name="InstructionsLabel" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="InstructionsHint" Opacity="0.7" TextWrapping="Wrap"
                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                        <TextBox x:Name="InstructionsBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="160" MaxHeight="400"
                                 Text="{x:Bind ViewModel.Instructions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="SaveInstructionsButton"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.SaveInstructionsCommand}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{x:Bind ViewModel.InstructionsSavedMessage, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.InstructionsSavedMessage, Mode=OneWay, Converter={StaticResource NullToCollapsed}}"
                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
