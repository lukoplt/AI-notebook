<Page
    x:Class="AINotebook.App.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:AINotebook.App.Controls"
    xmlns:vm="using:AINotebook.App.ViewModels"
    xmlns:models="using:AINotebook.Core.Models"
    xmlns:sys="using:System">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <!-- C4: citation panel -->
            <ColumnDefinition Width="{x:Bind CitationPanelWidth, Mode=OneWay}"/>
        </Grid.ColumnDefinitions>

        <!-- Sessions sidebar: a card so it reads as a separate panel, not as
             loose text floating next to the conversation. -->
        <Border Grid.Column="0" Margin="0,0,12,0" Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <TextBlock x:Name="SessionsLabel" Style="{ThemeResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button x:Name="NewSessionButton" HorizontalAlignment="Right" Command="{x:Bind ViewModel.NewSessionCommand}"
                        Content="&#xE710;" FontFamily="Segoe MDL2 Assets"/>
            </Grid>
            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatSession">
                        <StackPanel Spacing="2">
                            <StackPanel.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Name="DeleteSessionItem" Click="OnDeleteSession"
                                                    Tag="{x:Bind}"
                                                    Icon="Delete"/>
                                </MenuFlyout>
                            </StackPanel.ContextFlyout>
                            <TextBlock Text="{x:Bind Title}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind CreatedAt}" Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        </Border>

        <!-- Chat surface -->
        <Grid Grid.Column="1" Padding="4,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="10"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}">
                <FontIcon Glyph="&#xE8F2;" FontSize="36" Opacity="0.5"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyState" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="0" x:Name="MessagesScroller"
                          Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource InvertBoolToVisibility}}">
                <StackPanel Spacing="6">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageViewModel">
                                <ctrl:MessageBubble ViewModel="{x:Bind}"
                                                    CitationTapped="OnCitationTapped"
                                                    SaveAsNoteRequested="OnSaveAsNote"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border x:Name="StreamingBubble" CornerRadius="10" Padding="10"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            HorizontalAlignment="Left"
                            Visibility="{x:Bind ViewModel.StreamingDraft, Mode=OneWay, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{x:Bind ViewModel.StreamingDraft, Mode=OneWay}" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- C3: edit mode input -->
            <Grid Grid.Row="1" Margin="0,8,0,0" ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="EditInputBox" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                         Text="{x:Bind ViewModel.EditInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Style="{ThemeResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.CommitEditCommand}"
                        x:Name="CommitEditButton"/>
                <Button Grid.Column="2" Command="{x:Bind ViewModel.CancelEditCommand}"
                        x:Name="CancelEditButton"/>
            </Grid>

            <!-- Tier 2a follow-up chips + Tier 3 source-scope picker + C3 edit/regen buttons -->
            <StackPanel Grid.Row="2" Spacing="6" Margin="0,8,0,0">
                <StackPanel Spacing="4"
                            Visibility="{x:Bind ViewModel.HasFollowups, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock x:Name="FollowupsLabel" Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Followups, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Button Margin="0,0,0,4" HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Left"
                                        Click="OnFollowupTapped" Tag="{x:Bind}">
                                    <TextBlock Text="{x:Bind}" TextWrapping="Wrap"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ScopeButton" HorizontalAlignment="Left"
                            Content="{x:Bind ViewModel.ScopeButtonText, Mode=OneWay}">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="6" MinWidth="220">
                                    <TextBlock x:Name="ScopeTitle" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <ItemsControl ItemsSource="{x:Bind ViewModel.ScopeSources, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ScopeSourceItem">
                                                <CheckBox Content="{x:Bind Title}"
                                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- C2: source sets — apply a saved set as scope preset -->
                                    <Border Margin="0,4,0,0"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                            BorderThickness="0,1,0,0" Padding="0,6,0,0"
                                            Visibility="{x:Bind ViewModel.SourceSets.Count, Mode=OneWay, Converter={StaticResource CountToVisibility}}">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="SourceSetsLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <ItemsControl ItemsSource="{x:Bind ViewModel.SourceSets, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceSet">
                                                        <Grid Margin="0,2" ColumnSpacing="4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0" Content="{x:Bind Name}" Tag="{x:Bind}"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Click="OnApplySourceSet"
                                                                    Padding="6,4"/>
                                                            <Button Grid.Column="1" Tag="{x:Bind}"
                                                                    Click="OnDeleteSourceSet"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Padding="6,4">
                                                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button x:Name="AddSourceSetButton" Click="OnCreateSourceSet"
                                                    Margin="0,4,0,0" Padding="6,4"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <!-- C3: edit/regen actions -->
                    <Button x:Name="EditLastButton"
                            Command="{x:Bind ViewModel.EditLastCommand}"
                            Visibility="{x:Bind ViewModel.CanEditLast, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                    </Button>
                    <Button x:Name="RegenerateButton"
                            Command="{x:Bind ViewModel.RegenerateCommand}"
                            Visibility="{x:Bind ViewModel.CanEditLast, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <!-- E3: web search per-message toggle -->
                    <ToggleButton x:Name="WebSearchToggle"
                                  IsChecked="{x:Bind ViewModel.UseWebSearch, Mode=TwoWay}">
                        <FontIcon Glyph="&#xE721;" FontSize="14"/>
                    </ToggleButton>
                    <!-- C4: citation panel toggle -->
                    <Button x:Name="CitationPanelButton" Click="OnToggleCitationPanel">
                        <FontIcon Glyph="&#xE7C3;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Composer: input + a visible send button so the surface is
                 recognizable as a chat at a glance (Ctrl+Enter still works). -->
            <Grid Grid.Row="3" Margin="0,8,0,0" ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource InvertBoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="InputBox"
                         Text="{x:Bind ViewModel.Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                         IsEnabled="{x:Bind ViewModel.Sending, Mode=OneWay, Converter={StaticResource InvertBool}}">
                    <TextBox.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Enter" Invoked="OnSendAccelerator"/>
                    </TextBox.KeyboardAccelerators>
                </TextBox>
                <Button Grid.Column="1" x:Name="SendButton"
                        Style="{ThemeResource AccentButtonStyle}"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.SendCommand}">
                    <FontIcon Glyph="&#xE724;" FontSize="14"/>
                </Button>
            </Grid>
        </Grid>

        <!-- C4: citation panel (card, mirrors the sessions sidebar) -->
        <Border Grid.Column="2" Margin="12,0,0,0" Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8"
                Visibility="{x:Bind ViewModel.IsCitationPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <TextBlock x:Name="CitationPanelTitle" Style="{ThemeResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Command="{x:Bind ViewModel.CloseCitationPanelCommand}"
                        Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                </Button>
            </Grid>
            <ScrollViewer Grid.Row="1" Margin="0,8,0,0">
                <ItemsControl ItemsSource="{x:Bind ViewModel.PanelCitations, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CitationViewModel">
                            <Border Margin="0,4" Padding="10" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind SourceTitle}" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Snippet}" TextWrapping="Wrap" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        </Border>
    </Grid>
</Page>
