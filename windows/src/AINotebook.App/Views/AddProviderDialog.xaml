<ContentDialog
    x:Class="AINotebook.App.Views.AddProviderDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Width="440" MaxHeight="560">
        <StackPanel Spacing="16" Padding="4">
            <ComboBox x:Name="TypeCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="OnTypeChanged" />

            <TextBox x:Name="NameBox" HorizontalAlignment="Stretch"
                     TextChanged="OnFieldChanged" />

            <TextBox x:Name="UrlBox" HorizontalAlignment="Stretch"
                     TextChanged="OnFieldChanged" />

            <PasswordBox x:Name="KeyBox" HorizontalAlignment="Stretch"
                         PasswordChanged="OnFieldChanged" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="TestButton" Click="OnTest" />
                <ProgressRing x:Name="TestSpinner" Width="20" Height="20" IsActive="False" />
                <TextBlock x:Name="TestStatusText" VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="260"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <InfoBar x:Name="TestSuccessBar" Severity="Success" IsClosable="False" IsOpen="False" />

            <Button x:Name="DeleteButton" Visibility="Collapsed"
                    Click="OnDelete"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
