<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="AINotebook.App.Dialogs.TransformationHistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AINotebook.App.ViewModels"
    DefaultButton="Close">
    <Grid Width="640" Height="460" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" x:Name="RunsList"
                  ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                  SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="OnRowClick">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="IsEnabled" Value="{Binding HasNote}"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TransformationRunRow">
                    <Grid Padding="0,6" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{x:Bind TemplateName}" Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind SourceTitle}" Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind RanAt}" Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="" FontSize="12"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="1" x:Name="EmptyText" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="Collapsed"/>

        <TextBlock Grid.Row="2" x:Name="ErrorText"
                   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="Red" TextWrapping="Wrap"/>
    </Grid>
</ContentDialog>
