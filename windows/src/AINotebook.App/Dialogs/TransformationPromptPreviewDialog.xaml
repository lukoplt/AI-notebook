<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="AINotebook.App.Dialogs.TransformationPromptPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DefaultButton="Close">
    <Grid Width="640" Height="460">
        <ScrollViewer>
            <TextBlock x:Name="PreviewText" FontFamily="Consolas"
                       TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
        </ScrollViewer>
    </Grid>
</ContentDialog>
